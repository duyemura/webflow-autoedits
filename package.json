{
  "name": "grow-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx watch src/app-server.ts\" \"cd spa && pnpm dev\"",
    "dev:server": "tsx watch src/app-server.ts",
    "build": "tsc && cp -r src/templates dist/templates && cd spa && pnpm build",
    "start": "node dist/app-server.js",
    "test:system": "vitest run",
    "test:site": "tsx scripts/test-site.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/autoload": "^6.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@supabase/supabase-js": "^2.47.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.0.0",
    "handlebars": "^4.7.8",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/handlebars": "^4.1.0",
    "@types/node": "^22.10.0",
    "@vitest/runner": "^4.0.18",
    "concurrently": "^9.0.0",
    "playwright": "^1.58.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
