{
  "name": "webflow-autoedits",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx watch src/app-server.ts\" \"cd spa && pnpm dev\"",
    "dev:server": "tsx watch src/app-server.ts",
    "dev:pipeline": "tsx watch src/index.ts",
    "build": "tsc && cd spa && pnpm build",
    "start": "node dist/app-server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "dev:sync": "node scripts/dev-sync.mjs",
    "tunnel": "cloudflared tunnel --url http://localhost:3200 --metrics 127.0.0.1:20241"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/autoload": "^6.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/env": "^5.0.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "@modelcontextprotocol/sdk": "^1.6.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
