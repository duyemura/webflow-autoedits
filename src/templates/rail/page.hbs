<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{page.title}} — {{config.name}}</title>
  {{#if page.meta_description}}<meta name="description" content="{{page.meta_description}}" />{{/if}}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family={{config.font_heading}}:wght@400;700&family={{config.font_body}}:wght@400;500;600&display=swap&v={{buildVersion}}" rel="stylesheet" />

  <style>
    :root {
      --color-primary:   {{config.primary_color}};
      --color-secondary: {{config.secondary_color}};
      --color-accent:    {{config.accent_color}};
      --color-bg:        {{config.bg_color}};
      --color-text:      {{config.text_color}};
      --font-heading:    '{{config.font_heading}}', sans-serif;
      --font-body:       '{{config.font_body}}', sans-serif;
      --rail-width: 260px;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-body); color: var(--color-text); background: var(--color-bg); line-height: 1.6; display: flex; min-height: 100vh; }
    img { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }
    ul { list-style: none; }
    .btn { display: inline-block; padding: .7rem 1.5rem; border-radius: 4px; font-weight: 600; font-size: .9rem; transition: opacity .2s, transform .1s; cursor: pointer; }
    .btn:hover { opacity: .88; transform: translateY(-1px); }
    .btn--primary { background: var(--color-primary); color: #fff; }
    .btn--secondary { background: transparent; color: #fff; border: 2px solid rgba(255,255,255,.6); }

    /* Rail */
    .rail { position: fixed; top: 0; left: 0; width: var(--rail-width); height: 100vh; background: var(--color-secondary); display: flex; flex-direction: column; justify-content: space-between; padding: 2rem 1.5rem; z-index: 100; overflow-y: auto; }
    .rail__logo { display: block; margin-bottom: 2.5rem; }
    .rail__logo img { height: 36px; width: auto; }
    .rail__logo-text { font-family: var(--font-heading); font-size: 1.35rem; color: #fff; letter-spacing: .06em; }
    .rail__nav { display: flex; flex-direction: column; gap: .25rem; flex: 1; }
    .rail__link { color: rgba(255,255,255,.7); font-size: .92rem; padding: .55rem .75rem; border-radius: 4px; transition: background .15s, color .15s; }
    .rail__link:hover { background: rgba(255,255,255,.08); color: #fff; }
    .rail__cta { display: block; margin-top: 1.75rem; text-align: center; width: 100%; }
    .rail__bottom { border-top: 1px solid rgba(255,255,255,.1); padding-top: 1.25rem; margin-top: 1.5rem; }
    .rail__contact { display: flex; flex-direction: column; gap: .3rem; margin-bottom: 1rem; }
    .rail__contact-line { font-size: .82rem; color: rgba(255,255,255,.5); }
    .rail__socials { display: flex; gap: .85rem; }
    .rail__socials a { color: rgba(255,255,255,.4); transition: color .2s; }
    .rail__socials a:hover { color: rgba(255,255,255,.85); }
    .rail__toggle { display: none; position: fixed; top: 1rem; left: 1rem; z-index: 200; background: var(--color-secondary); border: none; color: #fff; font-size: 1.4rem; width: 44px; height: 44px; border-radius: 6px; cursor: pointer; align-items: center; justify-content: center; }
    @media (max-width: 768px) {
      .rail { transform: translateX(-100%); transition: transform .25s ease; }
      .rail.is-open { transform: translateX(0); }
      .rail__toggle { display: flex; }
      body { display: block; }
      .main { margin-left: 0 !important; }
    }

    .main { margin-left: var(--rail-width); flex: 1; min-width: 0; }

    /* Page Hero (compact) */
    .page-hero { background: var(--color-secondary); padding: 4rem 3rem; }
    .page-hero__headline { font-family: var(--font-heading); font-size: clamp(2rem, 5vw, 3.5rem); color: #fff; line-height: 1.1; letter-spacing: .02em; margin-bottom: .75rem; }
    .page-hero__subheading { font-size: 1.05rem; color: rgba(255,255,255,.75); max-width: 55ch; margin-bottom: 1.75rem; }
    .page-hero__ctas { display: flex; gap: 1rem; flex-wrap: wrap; }

    /* Sections */
    .section { padding: 4.5rem 3rem; }
    .section__header { margin-bottom: 2.5rem; }
    .section__heading { font-family: var(--font-heading); font-size: clamp(1.6rem, 3vw, 2.4rem); letter-spacing: .04em; color: var(--color-secondary); margin-bottom: .4rem; }
    .section__subheading { font-size: 1rem; color: #777; }
    .section--dark { background: var(--color-secondary); }
    .section--dark .section__heading { color: #fff; }
    .section--dark .section__subheading { color: rgba(255,255,255,.6); }
    .section--tinted { background: #f5f5f5; }

    .highlights__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; }
    .highlight-card { padding: 1.75rem; border-top: 3px solid var(--color-primary); background: #fff; box-shadow: 0 1px 8px rgba(0,0,0,.05); }
    .highlight-card__title { font-family: var(--font-heading); font-size: 1.2rem; letter-spacing: .05em; margin-bottom: .4rem; color: var(--color-secondary); }
    .highlight-card__body { color: #666; font-size: .92rem; }

    .programs__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.75rem; }
    .program-card { border-radius: 6px; overflow: hidden; box-shadow: 0 2px 16px rgba(0,0,0,.08); background: #fff; transition: transform .2s; }
    .program-card:hover { transform: translateY(-3px); }
    .program-card__img { width: 100%; height: 200px; object-fit: cover; }
    .program-card__body { padding: 1.35rem; }
    .program-card__title { font-family: var(--font-heading); font-size: 1.3rem; letter-spacing: .05em; margin-bottom: .4rem; color: var(--color-secondary); }
    .program-card__desc { color: #666; font-size: .9rem; margin-bottom: 1rem; }
    .program-card__link { color: var(--color-primary); font-weight: 600; font-size: .88rem; }

    .steps__list { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 2rem; }
    .step { position: relative; padding-top: 1rem; }
    .step__number { font-family: var(--font-heading); font-size: 4.5rem; line-height: 1; color: var(--color-primary); opacity: .12; position: absolute; top: 0; left: 0; }
    .step__content { position: relative; padding-top: .75rem; }
    .step__title { font-family: var(--font-heading); font-size: 1.25rem; letter-spacing: .05em; margin-bottom: .4rem; color: #fff; }
    .step__body { color: rgba(255,255,255,.7); font-size: .9rem; }

    .features__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.25rem; }
    .feature-card { padding: 1.35rem; background: #fff; border-radius: 6px; box-shadow: 0 1px 6px rgba(0,0,0,.05); }
    .feature-card__title { font-family: var(--font-heading); font-size: 1.05rem; letter-spacing: .04em; margin-bottom: .35rem; color: var(--color-secondary); }
    .feature-card__body { color: #777; font-size: .88rem; }

    .contact__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; }
    .contact__info h3 { font-family: var(--font-heading); font-size: 1rem; letter-spacing: .06em; text-transform: uppercase; color: var(--color-primary); margin-bottom: .75rem; }
    .contact__detail { display: flex; flex-direction: column; gap: .35rem; margin-bottom: 1.5rem; font-size: .95rem; color: #444; }
    .contact__detail a:hover { color: var(--color-primary); }
    .contact__hours { display: flex; flex-direction: column; gap: .25rem; }
    .contact__hours-row { display: flex; justify-content: space-between; font-size: .88rem; color: #555; padding: .25rem 0; border-bottom: 1px solid #f0f0f0; gap: 2rem; }
    .contact__map { border-radius: 6px; background: #eee; min-height: 300px; display: flex; align-items: center; justify-content: center; }
    .contact__map-placeholder { text-align: center; color: #999; font-size: .9rem; }
    @media (max-width: 768px) { .contact__grid { grid-template-columns: 1fr; } }

    .faq__list { max-width: 700px; display: flex; flex-direction: column; gap: .6rem; }
    .faq-item { border: 1px solid #eaeaea; border-radius: 5px; overflow: hidden; }
    .faq-item__question { width: 100%; background: #fff; border: none; padding: 1.1rem 1.35rem; text-align: left; font-family: var(--font-body); font-size: .97rem; font-weight: 600; color: var(--color-secondary); cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
    .faq-item__question::after { content: '+'; font-size: 1.3rem; font-weight: 300; flex-shrink: 0; transition: transform .2s; }
    .faq-item.is-open .faq-item__question::after { transform: rotate(45deg); }
    .faq-item__answer { display: none; padding: 0 1.35rem 1.1rem; color: #666; font-size: .92rem; line-height: 1.7; }
    .faq-item.is-open .faq-item__answer { display: block; }

    .cta-band { background: var(--color-primary); padding: 4rem 3rem; }
    .cta-band__heading { font-family: var(--font-heading); font-size: clamp(1.6rem, 3.5vw, 2.6rem); color: #fff; letter-spacing: .04em; margin-bottom: 1.5rem; max-width: 28ch; }

    .footer { background: #111; color: rgba(255,255,255,.35); padding: 1.5rem 3rem; font-size: .8rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
    .footer a { color: rgba(255,255,255,.4); transition: color .2s; }
    .footer a:hover { color: rgba(255,255,255,.8); }

    /* PushPress Schedule Widget */
    .pp-schedule { font-family: var(--font-body); }
    .pp-sched__days { display: flex; gap: .4rem; flex-wrap: wrap; margin-bottom: 1.75rem; }
    .pp-sched__day-btn { padding: .4rem .9rem; border-radius: 999px; border: 1.5px solid #e0e0e0; background: #fff; font-size: .82rem; font-weight: 500; color: #555; cursor: pointer; transition: all .15s; white-space: nowrap; }
    .pp-sched__day-btn:hover { border-color: var(--color-primary); color: var(--color-primary); }
    .pp-sched__day-btn.is-active { background: var(--color-primary); border-color: var(--color-primary); color: #fff; font-weight: 600; }
    .pp-sched__day-label { font-family: var(--font-heading); font-size: 1.05rem; letter-spacing: .04em; color: var(--color-secondary); margin-bottom: 1rem; }
    .pp-sched__list { display: flex; flex-direction: column; gap: .65rem; }
    .pp-sched__card { display: flex; align-items: center; gap: 1rem; background: #fff; border-radius: 6px; padding: 1.1rem 1.35rem; box-shadow: 0 1px 6px rgba(0,0,0,.06); border-left: 3px solid #ccc; transition: transform .15s, box-shadow .15s; }
    .pp-sched__card:hover { transform: translateY(-2px); box-shadow: 0 3px 12px rgba(0,0,0,.1); }
    .pp-sched__time { min-width: 72px; }
    .pp-sched__time-start { font-weight: 700; font-size: 1rem; color: var(--color-secondary); line-height: 1.2; }
    .pp-sched__time-end { font-size: .75rem; color: #aaa; }
    .pp-sched__info { flex: 1; min-width: 0; }
    .pp-sched__class-name { font-family: var(--font-heading); font-size: 1.05rem; letter-spacing: .03em; color: var(--color-secondary); margin-bottom: .15rem; }
    .pp-sched__meta { font-size: .8rem; color: #999; display: flex; gap: .65rem; flex-wrap: wrap; }
    .pp-sched__book a { display: inline-block; padding: .38rem .85rem; background: var(--color-primary); color: #fff; border-radius: 4px; font-size: .78rem; font-weight: 600; transition: opacity .2s; white-space: nowrap; }
    .pp-sched__book a:hover { opacity: .85; }
    .pp-sched__empty { padding: 1.75rem; text-align: center; color: #aaa; font-size: .9rem; background: #f5f5f5; border-radius: 6px; }
    .pp-sched__skeleton .pp-sk-card { height: 72px; border-radius: 6px; background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%); background-size: 200% 100%; animation: pp-shimmer 1.4s infinite; margin-bottom: .65rem; }
    @keyframes pp-shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
  </style>
</head>
<body>

{{> rail}}

<div class="main">

  <section class="page-hero" data-section="page-hero">
    <h1 class="page-hero__headline" data-content="hero.headline">{{page.hero_headline}}</h1>
    {{#if page.hero_subheading}}<p class="page-hero__subheading" data-content="hero.subheading">{{page.hero_subheading}}</p>{{/if}}
    {{#if page.hero_cta_text}}
    <div class="page-hero__ctas">
      <a href="{{page.hero_cta_url}}" class="btn btn--primary" data-content="hero.cta_primary">{{page.hero_cta_text}}</a>
      {{#if page.hero_secondary_cta_text}}<a href="{{page.hero_secondary_cta_url}}" class="btn btn--secondary" data-content="hero.cta_secondary">{{page.hero_secondary_cta_text}}</a>{{/if}}
    </div>
    {{/if}}
  </section>

  {{#each sections}}
    {{#eq section_type "highlights"}}
    <section class="section section--tinted" data-section="highlights">
      {{#if heading}}<div class="section__header"><h2 class="section__heading">{{heading}}</h2></div>{{/if}}
      <div class="highlights__grid">{{#each items}}<div class="highlight-card"><h3 class="highlight-card__title">{{title}}</h3><p class="highlight-card__body">{{short_body}}</p></div>{{/each}}</div>
    </section>
    {{/eq}}
    {{#eq section_type "programs"}}
    <section class="section" data-section="programs">
      {{#if heading}}<div class="section__header"><h2 class="section__heading">{{heading}}</h2>{{#if subheading}}<p class="section__subheading">{{subheading}}</p>{{/if}}</div>{{/if}}
      <div class="programs__grid">{{#each items}}<div class="program-card">{{#if image_url}}<img class="program-card__img" src="{{image_url}}" alt="{{title}}" />{{/if}}<div class="program-card__body"><h3 class="program-card__title">{{title}}</h3><p class="program-card__desc">{{short_body}}</p>{{#if cta_text}}<a href="{{cta_url}}" class="program-card__link">{{cta_text}} →</a>{{/if}}</div></div>{{/each}}</div>
    </section>
    {{/eq}}
    {{#eq section_type "steps"}}
    <section class="section section--dark" data-section="steps">
      {{#if heading}}<div class="section__header"><h2 class="section__heading">{{heading}}</h2>{{#if subheading}}<p class="section__subheading">{{subheading}}</p>{{/if}}</div>{{/if}}
      <div class="steps__list">{{#each items}}<div class="step"><div class="step__number">{{stepNumber @index}}</div><div class="step__content"><h3 class="step__title">{{title}}</h3><p class="step__body">{{short_body}}</p></div></div>{{/each}}</div>
    </section>
    {{/eq}}
    {{#eq section_type "features"}}
    <section class="section section--tinted" data-section="features">
      {{#if heading}}<div class="section__header"><h2 class="section__heading">{{heading}}</h2></div>{{/if}}
      <div class="features__grid">{{#each items}}<div class="feature-card"><h3 class="feature-card__title">{{title}}</h3><p class="feature-card__body">{{short_body}}</p></div>{{/each}}</div>
    </section>
    {{/eq}}
    {{#eq section_type "contact"}}
    <section class="section" data-section="contact">
      {{#if heading}}<div class="section__header"><h2 class="section__heading">{{heading}}</h2></div>{{/if}}
      <div class="contact__grid">
        <div class="contact__info">
          {{#if ../config.address}}<h3>Location</h3><div class="contact__detail"><p>{{../config.address}}</p><p>{{../config.city}}, {{../config.state}} {{../config.zip}}</p>{{#if ../config.google_maps_url}}<a href="{{../config.google_maps_url}}" target="_blank" rel="noopener">Get Directions →</a>{{/if}}</div>{{/if}}
          {{#if ../config.phone}}<h3>Contact</h3><div class="contact__detail"><a href="tel:{{../config.phone}}">{{../config.phone}}</a>{{#if ../config.email}}<a href="mailto:{{../config.email}}">{{../config.email}}</a>{{/if}}</div>{{/if}}
          {{#if ../config.hours}}<h3>Hours</h3><div class="contact__hours">{{#each ../config.hours}}<div class="contact__hours-row"><span>{{@key}}</span><span>{{this}}</span></div>{{/each}}</div>{{/if}}
        </div>
        <div class="contact__map">{{#if ../config.google_maps_url}}<div class="contact__map-placeholder"><p>📍 {{../config.city}}, {{../config.state}}</p><a href="{{../config.google_maps_url}}" target="_blank" rel="noopener" style="color:var(--color-primary);font-weight:600;">Open in Google Maps →</a></div>{{else}}<div class="contact__map-placeholder"><p>Add a Google Maps URL in site settings.</p></div>{{/if}}</div>
      </div>
    </section>
    {{/eq}}
    {{#eq section_type "faq"}}
    <section class="section" data-section="faq">
      {{#if heading}}<div class="section__header"><h2 class="section__heading">{{heading}}</h2></div>{{/if}}
      <div class="faq__list">{{#each items}}<div class="faq-item"><button class="faq-item__question">{{title}}</button><div class="faq-item__answer">{{body}}</div></div>{{/each}}</div>
    </section>
    {{/eq}}
    {{#eq section_type "cta"}}
    <section class="cta-band" data-section="cta">
      <h2 class="cta-band__heading">{{heading}}</h2>
      {{#if ../config.booking_url}}<a href="{{../config.booking_url}}" class="btn btn--secondary">Book a Free Call</a>{{/if}}
    </section>
    {{/eq}}
    {{#eq section_type "embed"}}
    <section class="section" data-section="embed">
      <div style="padding: 0 3rem 4.5rem;">
        {{#if heading}}<h2 style="font-family:var(--font-heading);font-size:clamp(1.6rem,3vw,2.4rem);letter-spacing:.04em;color:var(--color-secondary);margin-bottom:1.5rem;">{{heading}}</h2>{{/if}}
        {{{config.code}}}
      </div>
    </section>
    {{/eq}}
    {{#eq section_type "schedule"}}
    <section class="section" data-section="schedule">
      <div class="section__inner">
        {{#if heading}}<div class="section__header"><h2 class="section__heading">{{heading}}</h2>{{#if subheading}}<p class="section__subheading">{{subheading}}</p>{{/if}}</div>{{/if}}
        {{#if ../config.schedule_embed_url}}
          <div style="width:100%;min-height:600px;">
            <iframe src="{{../config.schedule_embed_url}}"
                    width="100%" height="700" frameborder="0"
                    style="border:none;border-radius:8px;"
                    title="Class Schedule"></iframe>
          </div>
        {{else}}
          <div class="pp-schedule"
               id="pp-schedule"
               data-site-id="{{../config.site_id}}"
               data-booking-url="{{../config.booking_url}}"
               data-phone="{{../config.phone}}">
            <div class="pp-sched__skeleton">
              <div class="pp-sk-card"></div><div class="pp-sk-card"></div><div class="pp-sk-card"></div>
            </div>
          </div>
        {{/if}}
      </div>
    </section>
    {{/eq}}
  {{/each}}

  <footer class="footer" data-section="footer">
    <span>&copy; {{year}} {{config.name}}. All rights reserved.</span>
    <span>{{#if config.phone}}<a href="tel:{{config.phone}}">{{config.phone}}</a>{{/if}}{{#if config.email}} &middot; <a href="mailto:{{config.email}}">{{config.email}}</a>{{/if}}</span>
  </footer>

</div>

<script>
  // FAQ accordion
  document.querySelectorAll('.faq-item__question').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const isOpen = item.classList.contains('is-open');
      document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('is-open'));
      if (!isOpen) item.classList.add('is-open');
    });
  });

  // Rail mobile toggle
  const toggle = document.querySelector('.rail__toggle');
  const rail = document.querySelector('.rail');
  toggle?.addEventListener('click', () => rail?.classList.toggle('is-open'));
  document.addEventListener('click', (e) => {
    if (rail?.classList.contains('is-open') && !rail.contains(e.target) && e.target !== toggle) rail.classList.remove('is-open');
  });

  // PushPress schedule widget
  (function () {
    const root = document.getElementById('pp-schedule');
    if (!root) return;
    const siteId = root.dataset.siteId;
    const bookingUrl = root.dataset.bookingUrl || '';
    const phone = root.dataset.phone || '';
    const contactLine = phone ? ' Give us a call at <a href="tel:' + phone + '">' + phone + '</a>.' : '';

    fetch('/api/sites/' + siteId + '/schedule')
      .then(function (r) { return r.json(); })
      .then(function (data) {
        if (!data.classes || data.classes.length === 0) {
          if (data.configured === false) {
            var bookBtn = bookingUrl
              ? ' <a href="' + bookingUrl + '" target="_blank" rel="noopener" style="display:inline-block;margin-top:1rem;padding:.6rem 1.4rem;background:var(--color-primary);color:#fff;border-radius:4px;font-weight:600;font-size:.9rem;">Book a Class →</a>'
              : '';
            root.innerHTML = '<div class="pp-sched__empty" style="padding:3rem 2rem;"><p style="font-size:1.05rem;font-weight:600;color:var(--color-secondary);margin-bottom:.5rem;">Live schedule coming soon</p><p style="color:#999;font-size:.9rem;">Connect your PushPress account in the chat to display real-time class availability.' + (phone ? ' Questions? Call <a href="tel:' + phone + '" style="color:var(--color-primary)">' + phone + '</a>.' : '') + '</p>' + bookBtn + '</div>';
          } else {
            root.innerHTML = '<p class="pp-sched__empty">No classes scheduled in the next 7 days.' + contactLine + '</p>';
          }
          return;
        }
        renderSchedule(data.classes);
      })
      .catch(function () {
        root.innerHTML = '<p class="pp-sched__empty">Class schedule temporarily unavailable.' + contactLine + '</p>';
      });

    function renderSchedule(classes) {
      var days = {};
      var dayOrder = [];
      classes.forEach(function (c) {
        if (!days[c.date]) { days[c.date] = { label: c.dayLabel, classes: [] }; dayOrder.push(c.date); }
        days[c.date].classes.push(c);
      });

      var activeDate = dayOrder[0];

      function renderDayTabs() {
        return '<div class="pp-sched__days">' +
          dayOrder.map(function (d) {
            var day = days[d];
            var label = day.label.split(',')[0];
            var num = day.label.split(' ').pop();
            var active = d === activeDate ? ' is-active' : '';
            return '<button class="pp-sched__day-btn' + active + '" data-date="' + d + '">' + label + ' ' + num + '</button>';
          }).join('') +
        '</div>';
      }

      function renderClasses(date) {
        var day = days[date];
        if (!day) return '';
        var cards = day.classes.map(function (c) {
          var bookBtn = bookingUrl
            ? '<div class="pp-sched__book"><a href="' + bookingUrl + '" target="_blank" rel="noopener">Book →</a></div>'
            : '';
          var meta = [c.durationMin + ' min', c.location].filter(Boolean).join(' · ');
          return '<div class="pp-sched__card" style="border-left-color:' + c.typeColor + '">' +
            '<div class="pp-sched__time"><div class="pp-sched__time-start">' + c.timeStart + '</div><div class="pp-sched__time-end">' + c.timeEnd + '</div></div>' +
            '<div class="pp-sched__info"><div class="pp-sched__class-name">' + c.title + '</div><div class="pp-sched__meta">' + meta + '</div></div>' +
            bookBtn +
          '</div>';
        }).join('');
        return '<div class="pp-sched__day-label">' + day.label + '</div><div class="pp-sched__list">' + cards + '</div>';
      }

      function render() {
        root.innerHTML = renderDayTabs() + renderClasses(activeDate);
        root.querySelectorAll('.pp-sched__day-btn').forEach(function (btn) {
          btn.addEventListener('click', function () {
            activeDate = btn.dataset.date;
            render();
          });
        });
      }

      render();
    }
  })();
</script>
</body>
</html>
