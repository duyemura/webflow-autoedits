<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{page.title}}</title>
  {{#if page.meta_description}}<meta name="description" content="{{page.meta_description}}" />{{/if}}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family={{config.font_heading}}:wght@400;700&family={{config.font_body}}:wght@400;500;600&display=swap" rel="stylesheet" />

  <style>
    /* ── Design Tokens ── */
    :root {
      --color-primary:   {{config.primary_color}};
      --color-secondary: {{config.secondary_color}};
      --color-accent:    {{config.accent_color}};
      --color-bg:        {{config.bg_color}};
      --color-text:      {{config.text_color}};
      --font-heading:    '{{config.font_heading}}', sans-serif;
      --font-body:       '{{config.font_body}}', sans-serif;
    }

    /* ── Reset ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-body); color: var(--color-text); background: var(--color-bg); line-height: 1.6; }
    img { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }
    ul { list-style: none; }

    /* ── Buttons ── */
    .btn { display: inline-block; padding: .75rem 1.75rem; border-radius: 4px; font-weight: 600; font-size: .95rem; transition: opacity .2s, transform .1s; cursor: pointer; }
    .btn:hover { opacity: .88; transform: translateY(-1px); }
    .btn--primary { background: var(--color-primary); color: #fff; }
    .btn--secondary { background: transparent; color: #fff; border: 2px solid #fff; }

    /* ── Navbar ── */
    .navbar { position: sticky; top: 0; z-index: 100; background: var(--color-secondary); padding: 0 1.5rem; }
    .navbar__inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; gap: 2rem; height: 72px; }
    .navbar__logo { flex-shrink: 0; }
    .navbar__logo img { height: 40px; width: auto; }
    .navbar__logo-text { font-family: var(--font-heading); font-size: 1.4rem; color: #fff; letter-spacing: .05em; }
    .navbar__nav { display: flex; gap: 1.75rem; flex: 1; }
    .navbar__link { color: rgba(255,255,255,.85); font-size: .95rem; transition: color .2s; }
    .navbar__link:hover { color: #fff; }
    .navbar__ctas { display: flex; gap: .75rem; margin-left: auto; }
    .navbar__hamburger { display: none; background: none; border: none; color: #fff; font-size: 1.5rem; cursor: pointer; margin-left: auto; }
    .navbar__mobile { display: none; flex-direction: column; gap: 1rem; padding: 1.25rem 1.5rem 1.5rem; background: var(--color-secondary); }
    .navbar__mobile.is-open { display: flex; }
    .navbar__mobile-link { color: rgba(255,255,255,.9); font-size: 1rem; }
    @media (max-width: 768px) {
      .navbar__nav, .navbar__ctas { display: none; }
      .navbar__hamburger { display: block; }
    }

    /* ── Hero ── */
    .hero { position: relative; min-height: 90vh; display: flex; align-items: center; overflow: hidden; }
    .hero__bg { position: absolute; inset: 0; background-size: cover; background-position: center; filter: brightness(.45); }
    .hero__content { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; padding: 6rem 1.5rem; }
    .hero__headline { font-family: var(--font-heading); font-size: clamp(2.8rem, 7vw, 5.5rem); color: #fff; line-height: 1.05; letter-spacing: .02em; max-width: 14ch; margin-bottom: 1.25rem; }
    .hero__subheading { font-size: clamp(1rem, 2vw, 1.25rem); color: rgba(255,255,255,.85); max-width: 50ch; margin-bottom: 2.5rem; }
    .hero__ctas { display: flex; gap: 1rem; flex-wrap: wrap; }

    /* ── Section base ── */
    .section { padding: 5rem 1.5rem; }
    .section__inner { max-width: 1200px; margin: 0 auto; }
    .section__header { text-align: center; margin-bottom: 3rem; }
    .section__heading { font-family: var(--font-heading); font-size: clamp(1.8rem, 4vw, 2.8rem); letter-spacing: .04em; color: var(--color-secondary); margin-bottom: .5rem; }
    .section__subheading { font-size: 1.05rem; color: #666; }
    .section--dark { background: var(--color-secondary); }
    .section--dark .section__heading { color: #fff; }
    .section--dark .section__subheading { color: rgba(255,255,255,.7); }
    .section--gray { background: #f7f7f7; }

    /* ── Highlights ── */
    .highlights__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 2rem; }
    .highlight-card { padding: 2rem; border-left: 4px solid var(--color-primary); background: #fff; box-shadow: 0 2px 12px rgba(0,0,0,.06); }
    .highlight-card__title { font-family: var(--font-heading); font-size: 1.3rem; letter-spacing: .05em; margin-bottom: .5rem; color: var(--color-secondary); }
    .highlight-card__body { color: #555; font-size: .95rem; }

    /* ── Programs ── */
    .programs__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; }
    .program-card { border-radius: 8px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,.1); background: #fff; transition: transform .2s; }
    .program-card:hover { transform: translateY(-4px); }
    .program-card__img { width: 100%; height: 220px; object-fit: cover; }
    .program-card__body { padding: 1.5rem; }
    .program-card__title { font-family: var(--font-heading); font-size: 1.4rem; letter-spacing: .05em; margin-bottom: .5rem; color: var(--color-secondary); }
    .program-card__desc { color: #555; font-size: .92rem; margin-bottom: 1.25rem; }
    .program-card__link { color: var(--color-primary); font-weight: 600; font-size: .9rem; }
    .program-card__link:hover { text-decoration: underline; }

    /* ── Steps ── */
    .steps__list { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 2.5rem; counter-reset: steps; }
    .step { position: relative; padding-left: 1rem; }
    .step__number { font-family: var(--font-heading); font-size: 5rem; line-height: 1; color: var(--color-primary); opacity: .15; position: absolute; top: -1rem; left: 0; }
    .step__content { position: relative; }
    .step__title { font-family: var(--font-heading); font-size: 1.3rem; letter-spacing: .05em; margin-bottom: .5rem; color: #fff; }
    .step__body { color: rgba(255,255,255,.75); font-size: .92rem; }

    /* ── Features ── */
    .features__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.5rem; }
    .feature-card { padding: 1.5rem; background: #fff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,.06); }
    .feature-card__title { font-family: var(--font-heading); font-size: 1.1rem; letter-spacing: .04em; margin-bottom: .4rem; color: var(--color-secondary); }
    .feature-card__body { color: #666; font-size: .9rem; }

    /* ── FAQ ── */
    .faq__list { max-width: 760px; margin: 0 auto; display: flex; flex-direction: column; gap: .75rem; }
    .faq-item { border: 1px solid #e5e5e5; border-radius: 6px; overflow: hidden; }
    .faq-item__question { width: 100%; background: #fff; border: none; padding: 1.25rem 1.5rem; text-align: left; font-family: var(--font-body); font-size: 1rem; font-weight: 600; color: var(--color-secondary); cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
    .faq-item__question::after { content: '+'; font-size: 1.4rem; font-weight: 300; flex-shrink: 0; transition: transform .2s; }
    .faq-item.is-open .faq-item__question::after { transform: rotate(45deg); }
    .faq-item__answer { display: none; padding: 0 1.5rem 1.25rem; color: #555; font-size: .95rem; line-height: 1.7; }
    .faq-item.is-open .faq-item__answer { display: block; }

    /* ── CTA Band ── */
    .cta-band { background: var(--color-primary); padding: 4rem 1.5rem; text-align: center; }
    .cta-band__heading { font-family: var(--font-heading); font-size: clamp(1.8rem, 4vw, 3rem); color: #fff; letter-spacing: .04em; margin-bottom: 1.75rem; }
    .cta-band .btn--secondary { border-color: rgba(255,255,255,.6); }

    /* ── Footer ── */
    .footer { background: #111; color: rgba(255,255,255,.8); padding: 4rem 1.5rem 0; }
    .footer__inner { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 3rem; padding-bottom: 3rem; }
    .footer__logo-text { font-family: var(--font-heading); font-size: 1.5rem; color: #fff; letter-spacing: .06em; }
    .footer__logo img { height: 36px; width: auto; margin-bottom: .75rem; }
    .footer__tagline { font-size: .9rem; color: rgba(255,255,255,.5); margin-top: .5rem; margin-bottom: 1.25rem; }
    .footer__socials { display: flex; gap: 1rem; }
    .footer__socials a { color: rgba(255,255,255,.6); transition: color .2s; }
    .footer__socials a:hover { color: #fff; }
    .footer h4 { font-family: var(--font-heading); font-size: 1rem; letter-spacing: .08em; color: rgba(255,255,255,.4); text-transform: uppercase; margin-bottom: 1rem; }
    .footer__links ul { display: flex; flex-direction: column; gap: .6rem; }
    .footer__links a { color: rgba(255,255,255,.7); font-size: .9rem; transition: color .2s; }
    .footer__links a:hover { color: #fff; }
    .footer__contact p { font-size: .9rem; color: rgba(255,255,255,.7); margin-bottom: .4rem; }
    .footer__contact a:hover { color: #fff; }
    .footer__hours { margin-top: .75rem; display: flex; flex-direction: column; gap: .2rem; }
    .footer__hours-row { display: flex; justify-content: space-between; font-size: .82rem; color: rgba(255,255,255,.5); gap: 1rem; }
    .footer__bottom { border-top: 1px solid rgba(255,255,255,.1); padding: 1.25rem 0; max-width: 1200px; margin: 0 auto; font-size: .82rem; color: rgba(255,255,255,.35); }
    @media (max-width: 768px) {
      .footer__inner { grid-template-columns: 1fr; gap: 2rem; }
    }
  </style>
</head>
<body>

{{> navbar}}

<!-- HERO -->
<section class="hero" data-section="hero">
  <div class="hero__bg" style="background-image: url('{{page.hero_image_url}}')" data-content="hero.image"></div>
  <div class="hero__content">
    <h1 class="hero__headline" data-content="hero.headline">{{page.hero_headline}}</h1>
    <p class="hero__subheading" data-content="hero.subheading">{{page.hero_subheading}}</p>
    <div class="hero__ctas">
      {{#if page.hero_cta_text}}
        <a href="{{page.hero_cta_url}}" class="btn btn--primary" data-content="hero.cta_primary">{{page.hero_cta_text}}</a>
      {{/if}}
      {{#if page.hero_secondary_cta_text}}
        <a href="{{page.hero_secondary_cta_url}}" class="btn btn--secondary" data-content="hero.cta_secondary">{{page.hero_secondary_cta_text}}</a>
      {{/if}}
    </div>
  </div>
</section>

{{#each sections}}

  {{!-- HIGHLIGHTS --}}
  {{#eq section_type "highlights"}}
  <section class="section section--gray" data-section="highlights">
    <div class="section__inner">
      {{#if heading}}<div class="section__header"><h2 class="section__heading" data-content="highlights.heading">{{heading}}</h2></div>{{/if}}
      <div class="highlights__grid" data-content="highlights.items">
        {{#each items}}
        <div class="highlight-card">
          <h3 class="highlight-card__title" data-content="highlight.{{@index}}.title">{{title}}</h3>
          <p class="highlight-card__body" data-content="highlight.{{@index}}.body">{{short_body}}</p>
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/eq}}

  {{!-- PROGRAMS --}}
  {{#eq section_type "programs"}}
  <section class="section" data-section="programs">
    <div class="section__inner">
      {{#if heading}}
      <div class="section__header">
        <h2 class="section__heading" data-content="programs.heading">{{heading}}</h2>
        {{#if subheading}}<p class="section__subheading" data-content="programs.subheading">{{subheading}}</p>{{/if}}
      </div>
      {{/if}}
      <div class="programs__grid" data-content="programs.items">
        {{#each items}}
        <div class="program-card">
          {{#if image_url}}<img class="program-card__img" src="{{image_url}}" alt="{{title}}" data-content="program.{{@index}}.image" />{{/if}}
          <div class="program-card__body">
            <h3 class="program-card__title" data-content="program.{{@index}}.title">{{title}}</h3>
            <p class="program-card__desc" data-content="program.{{@index}}.body">{{short_body}}</p>
            {{#if cta_text}}<a href="{{cta_url}}" class="program-card__link" data-content="program.{{@index}}.cta">{{cta_text}} →</a>{{/if}}
          </div>
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/eq}}

  {{!-- STEPS --}}
  {{#eq section_type "steps"}}
  <section class="section section--dark" data-section="steps">
    <div class="section__inner">
      {{#if heading}}
      <div class="section__header">
        <h2 class="section__heading" data-content="steps.heading">{{heading}}</h2>
        {{#if subheading}}<p class="section__subheading" data-content="steps.subheading">{{subheading}}</p>{{/if}}
      </div>
      {{/if}}
      <div class="steps__list" data-content="steps.items">
        {{#each items}}
        <div class="step">
          <div class="step__number">{{#if metadata.step_number}}{{metadata.step_number}}{{else}}{{stepNumber @index}}{{/if}}</div>
          <div class="step__content">
            <h3 class="step__title" data-content="step.{{@index}}.title">{{title}}</h3>
            <p class="step__body" data-content="step.{{@index}}.body">{{short_body}}</p>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/eq}}

  {{!-- FEATURES --}}
  {{#eq section_type "features"}}
  <section class="section section--gray" data-section="features">
    <div class="section__inner">
      {{#if heading}}<div class="section__header"><h2 class="section__heading" data-content="features.heading">{{heading}}</h2></div>{{/if}}
      <div class="features__grid" data-content="features.items">
        {{#each items}}
        <div class="feature-card">
          <h3 class="feature-card__title" data-content="feature.{{@index}}.title">{{title}}</h3>
          <p class="feature-card__body" data-content="feature.{{@index}}.body">{{short_body}}</p>
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/eq}}

  {{!-- FAQ --}}
  {{#eq section_type "faq"}}
  <section class="section" data-section="faq">
    <div class="section__inner">
      {{#if heading}}<div class="section__header"><h2 class="section__heading" data-content="faq.heading">{{heading}}</h2></div>{{/if}}
      <div class="faq__list" data-content="faq.items">
        {{#each items}}
        <div class="faq-item">
          <button class="faq-item__question" data-content="faq.{{@index}}.question">{{title}}</button>
          <div class="faq-item__answer" data-content="faq.{{@index}}.answer">{{body}}</div>
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/eq}}

  {{!-- CTA BAND --}}
  {{#eq section_type "cta"}}
  <section class="cta-band" data-section="cta">
    <h2 class="cta-band__heading" data-content="cta.heading">{{heading}}</h2>
    {{#if ../config.booking_url}}
      <a href="{{../config.booking_url}}" class="btn btn--secondary" data-content="cta.button">Book a Free Call</a>
    {{/if}}
  </section>
  {{/eq}}

  {{!-- EMBED (iframes, scripts, forms, widgets) --}}
  {{#eq section_type "embed"}}
  <section class="section embed-section" data-section="embed">
    <div class="section__inner">
      {{#if heading}}<div class="section__header"><h2 class="section__heading">{{heading}}</h2>{{#if subheading}}<p class="section__subheading">{{subheading}}</p>{{/if}}</div>{{/if}}
      {{{config.code}}}
    </div>
  </section>
  {{/eq}}

{{/each}}

{{> footer}}

<script>
  // FAQ accordion
  document.querySelectorAll('.faq-item__question').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const isOpen = item.classList.contains('is-open');
      document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('is-open'));
      if (!isOpen) item.classList.add('is-open');
    });
  });
</script>

</body>
</html>
