<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{page.title}} — {{config.name}}</title>
  {{#if page.meta_description}}<meta name="description" content="{{page.meta_description}}" />{{/if}}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family={{config.font_heading}}:wght@400;700&family={{config.font_body}}:wght@400;500;600&display=swap&v={{buildVersion}}" rel="stylesheet" />

  <style>
    :root {
      --color-primary:   {{config.primary_color}};
      --color-secondary: {{config.secondary_color}};
      --color-accent:    {{config.accent_color}};
      --color-bg:        {{config.bg_color}};
      --color-text:      {{config.text_color}};
      --font-heading:    '{{config.font_heading}}', sans-serif;
      --font-body:       '{{config.font_body}}', sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-body); color: var(--color-text); background: var(--color-bg); line-height: 1.6; }
    img { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }
    ul { list-style: none; }

    .btn { display: inline-block; padding: .75rem 1.75rem; border-radius: 4px; font-weight: 600; font-size: .95rem; transition: opacity .2s, transform .1s; cursor: pointer; }
    .btn:hover { opacity: .88; transform: translateY(-1px); }
    .btn--primary { background: var(--color-primary); color: #fff; }
    .btn--secondary { background: transparent; color: #fff; border: 2px solid rgba(255,255,255,.6); }

    /* ── Landing nav — logo only, no exits ── */
    .lnav { background: var(--color-secondary); padding: 0 1.5rem; }
    .lnav__inner { max-width: 1200px; margin: 0 auto; display: flex; align-items: center; height: 64px; }
    .lnav__logo img { height: 36px; width: auto; }
    .lnav__logo-text { font-family: var(--font-heading); font-size: 1.3rem; color: #fff; letter-spacing: .05em; }

    /* ── Hero ── */
    .hero { position: relative; min-height: 88vh; display: flex; align-items: center; overflow: hidden; }
    .hero__bg { position: absolute; inset: 0; background-size: cover; background-position: center; filter: brightness(.4); }
    .hero__content { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; padding: 6rem 1.5rem; }
    .hero__headline { font-family: var(--font-heading); font-size: clamp(2.8rem, 7vw, 5.5rem); color: #fff; line-height: 1.05; letter-spacing: .02em; max-width: 16ch; margin-bottom: 1.25rem; }
    .hero__subheading { font-size: clamp(1rem, 2vw, 1.25rem); color: rgba(255,255,255,.85); max-width: 50ch; margin-bottom: 2.5rem; }
    .hero__ctas { display: flex; gap: 1rem; flex-wrap: wrap; }
    .hero__trust { margin-top: 2rem; font-size: .82rem; color: rgba(255,255,255,.45); letter-spacing: .04em; }

    /* ── Sections ── */
    .section { padding: 5rem 1.5rem; }
    .section__inner { max-width: 1200px; margin: 0 auto; }
    .section__header { text-align: center; margin-bottom: 3rem; }
    .section__heading { font-family: var(--font-heading); font-size: clamp(1.8rem, 4vw, 2.8rem); letter-spacing: .04em; color: var(--color-secondary); margin-bottom: .5rem; }
    .section__subheading { font-size: 1.05rem; color: #666; }
    .section--dark { background: var(--color-secondary); }
    .section--dark .section__heading { color: #fff; }
    .section--dark .section__subheading { color: rgba(255,255,255,.7); }
    .section--gray { background: #f7f7f7; }

    .highlights__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 2rem; }
    .highlight-card { padding: 2rem; border-left: 4px solid var(--color-primary); background: #fff; box-shadow: 0 2px 12px rgba(0,0,0,.06); }
    .highlight-card__title { font-family: var(--font-heading); font-size: 1.3rem; letter-spacing: .05em; margin-bottom: .5rem; color: var(--color-secondary); }
    .highlight-card__body { color: #555; font-size: .95rem; }

    .steps__list { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 2.5rem; }
    .step { position: relative; padding-left: 1rem; }
    .step__number { font-family: var(--font-heading); font-size: 5rem; line-height: 1; color: var(--color-primary); opacity: .15; position: absolute; top: -1rem; left: 0; }
    .step__content { position: relative; }
    .step__title { font-family: var(--font-heading); font-size: 1.3rem; letter-spacing: .05em; margin-bottom: .5rem; color: #fff; }
    .step__body { color: rgba(255,255,255,.75); font-size: .92rem; }

    .faq__list { max-width: 760px; margin: 0 auto; display: flex; flex-direction: column; gap: .75rem; }
    .faq-item { border: 1px solid #e5e5e5; border-radius: 6px; overflow: hidden; }
    .faq-item__question { width: 100%; background: #fff; border: none; padding: 1.25rem 1.5rem; text-align: left; font-family: var(--font-body); font-size: 1rem; font-weight: 600; color: var(--color-secondary); cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
    .faq-item__question::after { content: '+'; font-size: 1.4rem; font-weight: 300; flex-shrink: 0; transition: transform .2s; }
    .faq-item.is-open .faq-item__question::after { transform: rotate(45deg); }
    .faq-item__answer { display: none; padding: 0 1.5rem 1.25rem; color: #555; font-size: .95rem; line-height: 1.7; }
    .faq-item.is-open .faq-item__answer { display: block; }

    .cta-band { background: var(--color-primary); padding: 5rem 1.5rem; text-align: center; }
    .cta-band__heading { font-family: var(--font-heading); font-size: clamp(2rem, 4vw, 3.2rem); color: #fff; letter-spacing: .04em; margin-bottom: .75rem; }
    .cta-band__sub { font-size: .9rem; color: rgba(255,255,255,.6); margin-bottom: 2rem; }
    .cta-band .btn--secondary { border-color: rgba(255,255,255,.6); }

    .embed-section .section__inner { max-width: 860px; }

    /* ── Landing footer — minimal, no nav ── */
    .lfooter { background: #111; padding: 1.25rem 1.5rem; text-align: center; font-size: .8rem; color: rgba(255,255,255,.3); }
    .lfooter a { color: rgba(255,255,255,.4); margin: 0 .5rem; }
    .lfooter a:hover { color: rgba(255,255,255,.7); }
  </style>
</head>
<body>

<!-- LOGO ONLY NAV -->
<nav class="lnav" data-section="navbar">
  <div class="lnav__inner">
    <a href="/" class="lnav__logo">
      {{#if config.logo_url}}
        <img src="{{config.logo_url}}" alt="{{config.name}}" />
      {{else}}
        <span class="lnav__logo-text">{{config.name}}</span>
      {{/if}}
    </a>
  </div>
</nav>

<!-- HERO -->
<section class="hero" data-section="hero">
  <div class="hero__bg" style="background-image: url('{{page.hero_image_url}}')" data-content="hero.image"></div>
  <div class="hero__content">
    <h1 class="hero__headline" data-content="hero.headline">{{page.hero_headline}}</h1>
    <p class="hero__subheading" data-content="hero.subheading">{{page.hero_subheading}}</p>
    <div class="hero__ctas">
      {{#if page.hero_cta_text}}
        <a href="{{page.hero_cta_url}}" class="btn btn--primary" data-content="hero.cta_primary">{{page.hero_cta_text}}</a>
      {{/if}}
      {{#if page.hero_secondary_cta_text}}
        <a href="{{page.hero_secondary_cta_url}}" class="btn btn--secondary" data-content="hero.cta_secondary">{{page.hero_secondary_cta_text}}</a>
      {{/if}}
    </div>
    <p class="hero__trust">No credit card &nbsp;·&nbsp; No commitment &nbsp;·&nbsp; Cancel anytime</p>
  </div>
</section>

{{#each sections}}

  {{#eq section_type "highlights"}}
  <section class="section section--gray" data-section="highlights">
    <div class="section__inner">
      {{#if heading}}<div class="section__header"><h2 class="section__heading">{{heading}}</h2>{{#if subheading}}<p class="section__subheading">{{subheading}}</p>{{/if}}</div>{{/if}}
      <div class="highlights__grid">
        {{#each items}}
        <div class="highlight-card">
          <h3 class="highlight-card__title">{{title}}</h3>
          <p class="highlight-card__body">{{short_body}}</p>
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/eq}}

  {{#eq section_type "steps"}}
  <section class="section section--dark" data-section="steps">
    <div class="section__inner">
      {{#if heading}}<div class="section__header"><h2 class="section__heading">{{heading}}</h2>{{#if subheading}}<p class="section__subheading">{{subheading}}</p>{{/if}}</div>{{/if}}
      <div class="steps__list">
        {{#each items}}
        <div class="step">
          <div class="step__number">{{stepNumber @index}}</div>
          <div class="step__content">
            <h3 class="step__title">{{title}}</h3>
            <p class="step__body">{{short_body}}</p>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/eq}}

  {{#eq section_type "faq"}}
  <section class="section" data-section="faq">
    <div class="section__inner">
      {{#if heading}}<div class="section__header"><h2 class="section__heading">{{heading}}</h2></div>{{/if}}
      <div class="faq__list">
        {{#each items}}
        <div class="faq-item">
          <button class="faq-item__question">{{title}}</button>
          <div class="faq-item__answer">{{body}}</div>
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/eq}}

  {{#eq section_type "embed"}}
  <section class="section embed-section" data-section="embed">
    <div class="section__inner">
      {{#if heading}}<div class="section__header"><h2 class="section__heading">{{heading}}</h2>{{#if subheading}}<p class="section__subheading">{{subheading}}</p>{{/if}}</div>{{/if}}
      {{{config.code}}}
    </div>
  </section>
  {{/eq}}

  {{#eq section_type "cta"}}
  <section class="cta-band" data-section="cta">
    <h2 class="cta-band__heading">{{heading}}</h2>
    {{#if subheading}}<p class="cta-band__sub">{{subheading}}</p>{{/if}}
    {{#if ../config.booking_url}}
      <a href="{{../config.booking_url}}" class="btn btn--secondary">Book a Free Call</a>
    {{/if}}
  </section>
  {{/eq}}

{{/each}}

<!-- MINIMAL FOOTER -->
<footer class="lfooter" data-section="footer">
  &copy; {{year}} {{config.name}}.
  {{#if config.phone}}<a href="tel:{{config.phone}}">{{config.phone}}</a>{{/if}}
  {{#if config.email}}<a href="mailto:{{config.email}}">{{config.email}}</a>{{/if}}
</footer>

<script>
  document.querySelectorAll('.faq-item__question').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const isOpen = item.classList.contains('is-open');
      document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('is-open'));
      if (!isOpen) item.classList.add('is-open');
    });
  });
</script>
</body>
</html>
