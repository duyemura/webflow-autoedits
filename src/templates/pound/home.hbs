<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{page.title}}</title>
  {{#if page.meta_description}}<meta name="description" content="{{page.meta_description}}" />{{/if}}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- Pound template: Kanit for headings, Lato for body — mirrors Kilo's type stack -->
  <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@400;600;700;800&family=Lato:wght@400;500;700&display=swap&v={{buildVersion}}" rel="stylesheet" />

  <style>
    /* ── Design Tokens ── */
    :root {
      --color-primary:   {{config.primary_color}};
      --color-secondary: {{config.secondary_color}};
      --color-accent:    {{config.accent_color}};
      --color-bg:        {{config.bg_color}};
      --color-text:      {{config.text_color}};
      --font-heading:    'Kanit', sans-serif;
      --font-body:       'Lato', sans-serif;
      --radius-card:     12px;
      --radius-hero-img: 0 0 0 80px;
      --dark:            #111111;
      --dark-2:          #1a1a1a;
      --mid:             #f4f4f4;
    }

    /* ── Reset ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font-body); color: var(--color-text); background: var(--color-bg, #fff); line-height: 1.6; }
    img { display: block; max-width: 100%; }
    a { color: inherit; text-decoration: none; }
    ul { list-style: none; }

    /* ── Buttons ── */
    .btn {
      display: inline-block;
      padding: .8rem 1.9rem;
      border-radius: 4px;
      font-family: var(--font-body);
      font-weight: 700;
      font-size: .95rem;
      letter-spacing: .04em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background .2s, transform .1s, box-shadow .2s;
    }
    .btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,.2); }
    .btn--primary { background: var(--color-primary); color: #fff; }
    .btn--primary:hover { background: color-mix(in srgb, var(--color-primary) 85%, #000); }
    .btn--outline { background: transparent; color: #fff; border: 2px solid rgba(255,255,255,.7); }
    .btn--outline:hover { border-color: #fff; }
    .btn--dark { background: var(--dark); color: #fff; }
    .btn--dark:hover { background: #222; }

    /* ── Navbar ── */
    .navbar {
      position: sticky;
      top: 0;
      z-index: 200;
      background: rgba(17, 17, 17, 0.92);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255,255,255,.06);
      transition: background .3s, box-shadow .3s;
    }
    .navbar.is-scrolled {
      background: rgba(17, 17, 17, 0.98);
      box-shadow: 0 4px 24px rgba(0,0,0,.4);
    }
    .navbar__inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1.5rem;
      display: flex;
      align-items: center;
      height: 70px;
      gap: 2rem;
    }
    .navbar__logo { flex-shrink: 0; }
    .navbar__logo img { height: 38px; width: auto; }
    .navbar__logo-text {
      font-family: var(--font-heading);
      font-size: 1.5rem;
      font-weight: 800;
      color: #fff;
      letter-spacing: .06em;
      text-transform: uppercase;
    }
    .navbar__nav { display: flex; gap: 1.75rem; flex: 1; }
    .navbar__link {
      color: rgba(255,255,255,.75);
      font-size: .9rem;
      font-weight: 500;
      letter-spacing: .04em;
      text-transform: uppercase;
      transition: color .2s;
    }
    .navbar__link:hover { color: #fff; }
    .navbar__ctas { margin-left: auto; display: flex; gap: .75rem; }
    .navbar__cta-btn { padding: .6rem 1.4rem; font-size: .85rem; }
    .navbar__hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      background: none;
      border: none;
      cursor: pointer;
      padding: .5rem;
      margin-left: auto;
    }
    .navbar__hamburger span {
      display: block;
      width: 24px;
      height: 2px;
      background: #fff;
      border-radius: 2px;
      transition: transform .3s, opacity .2s;
    }
    .navbar__hamburger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .navbar__hamburger.is-open span:nth-child(2) { opacity: 0; }
    .navbar__hamburger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
    .navbar__mobile {
      flex-direction: column;
      gap: .5rem;
      padding: 1rem 1.5rem 1.5rem;
      background: var(--dark-2);
      border-top: 1px solid rgba(255,255,255,.08);
    }
    .navbar__mobile:not([hidden]) { display: flex; }
    .navbar__mobile-link {
      color: rgba(255,255,255,.85);
      font-size: .95rem;
      font-weight: 500;
      padding: .5rem 0;
      border-bottom: 1px solid rgba(255,255,255,.07);
      letter-spacing: .03em;
    }
    .navbar__mobile-link.btn { border-bottom: none; text-align: center; margin-top: .5rem; }
    @media (max-width: 768px) {
      .navbar__nav, .navbar__ctas { display: none; }
      .navbar__hamburger { display: flex; }
    }

    /* ── Hero (Split Layout) ── */
    .hero {
      background: var(--dark);
      min-height: 88vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      overflow: hidden;
    }
    .hero__content {
      padding: 5rem 2rem 5rem clamp(1.5rem, 5vw, 6rem);
      max-width: 620px;
    }
    .hero__eyebrow {
      display: inline-block;
      font-size: .78rem;
      font-weight: 700;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--color-primary);
      margin-bottom: 1.25rem;
    }
    .hero__headline {
      font-family: var(--font-heading);
      font-size: clamp(2.6rem, 5.5vw, 4.8rem);
      font-weight: 800;
      line-height: 1.02;
      letter-spacing: .01em;
      color: #fff;
      text-transform: uppercase;
      margin-bottom: 1.5rem;
    }
    .hero__headline em {
      font-style: normal;
      color: var(--color-primary);
    }
    .hero__subheading {
      font-size: clamp(1rem, 1.8vw, 1.15rem);
      color: rgba(255,255,255,.7);
      max-width: 46ch;
      margin-bottom: 2.5rem;
      line-height: 1.65;
    }
    .hero__ctas { display: flex; gap: 1rem; flex-wrap: wrap; }
    .hero__image {
      position: relative;
      align-self: stretch;
      overflow: hidden;
    }
    .hero__image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
      border-radius: var(--radius-hero-img);
      min-height: 480px;
    }
    .hero__image::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to right, var(--dark) 0%, transparent 30%);
      z-index: 1;
      border-radius: var(--radius-hero-img);
    }
    @media (max-width: 900px) {
      .hero { grid-template-columns: 1fr; min-height: unset; }
      .hero__content { max-width: 100%; padding: 4rem 1.5rem 2rem; }
      .hero__image { height: 380px; }
      .hero__image img { min-height: unset; border-radius: 0; }
      .hero__image::before { display: none; }
    }

    /* ── Section base ── */
    .section { padding: 5rem 1.5rem; }
    .section__inner { max-width: 1200px; margin: 0 auto; }
    .section__header { text-align: center; margin-bottom: 3.5rem; }
    .section__label {
      display: inline-block;
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--color-primary);
      margin-bottom: .75rem;
    }
    .section__heading {
      font-family: var(--font-heading);
      font-size: clamp(1.9rem, 4vw, 3rem);
      font-weight: 800;
      letter-spacing: .03em;
      text-transform: uppercase;
      color: var(--dark);
      line-height: 1.08;
    }
    .section__subheading { font-size: 1.05rem; color: #666; margin-top: .75rem; max-width: 56ch; margin-left: auto; margin-right: auto; }
    .section--dark { background: var(--dark); }
    .section--dark .section__heading { color: #fff; }
    .section--dark .section__subheading { color: rgba(255,255,255,.6); }
    .section--dark .section__label { color: var(--color-primary); }
    .section--mid { background: var(--mid); }

    /* ── Highlights ── */
    .highlights__grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.5rem;
    }
    .highlight-card {
      background: #fff;
      border-radius: var(--radius-card);
      padding: 2rem 1.75rem;
      box-shadow: 0 2px 16px rgba(0,0,0,.07);
      border-top: 3px solid var(--color-primary);
      transition: transform .2s, box-shadow .2s;
    }
    .highlight-card:hover { transform: translateY(-4px); box-shadow: 0 8px 28px rgba(0,0,0,.12); }
    .highlight-card__icon {
      width: 40px;
      height: 40px;
      border-radius: 8px;
      background: color-mix(in srgb, var(--color-primary) 12%, transparent);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.1rem;
      color: var(--color-primary);
      font-size: 1.2rem;
    }
    .highlight-card__title {
      font-family: var(--font-heading);
      font-size: 1.2rem;
      font-weight: 700;
      letter-spacing: .04em;
      text-transform: uppercase;
      color: var(--dark);
      margin-bottom: .5rem;
    }
    .highlight-card__body { color: #555; font-size: .93rem; line-height: 1.65; }

    /* ── Programs ── */
    .programs__grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.75rem;
    }
    .program-card {
      border-radius: var(--radius-card);
      overflow: hidden;
      background: #fff;
      box-shadow: 0 4px 20px rgba(0,0,0,.09);
      transition: transform .25s, box-shadow .25s;
      display: flex;
      flex-direction: column;
    }
    .program-card:hover { transform: translateY(-6px); box-shadow: 0 12px 36px rgba(0,0,0,.15); }
    .program-card__img-wrap { position: relative; overflow: hidden; height: 230px; flex-shrink: 0; }
    .program-card__img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
    .program-card:hover .program-card__img { transform: scale(1.04); }
    .program-card__overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(0,0,0,.55) 0%, transparent 60%);
    }
    .program-card__body { padding: 1.5rem 1.75rem 1.75rem; flex: 1; display: flex; flex-direction: column; }
    .program-card__title {
      font-family: var(--font-heading);
      font-size: 1.35rem;
      font-weight: 700;
      letter-spacing: .05em;
      text-transform: uppercase;
      color: var(--dark);
      margin-bottom: .5rem;
    }
    .program-card__desc { color: #555; font-size: .92rem; line-height: 1.65; flex: 1; margin-bottom: 1.25rem; }
    .program-card__cta {
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      font-weight: 700;
      font-size: .88rem;
      letter-spacing: .06em;
      text-transform: uppercase;
      color: var(--color-primary);
      transition: gap .2s;
    }
    .program-card__cta:hover { gap: .7rem; }

    /* ── Steps (3-step process on dark bg) ── */
    .steps__grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 2rem;
      position: relative;
    }
    .steps__connector {
      display: none;
    }
    @media (min-width: 768px) {
      .steps__connector { display: block; }
    }
    .step {
      position: relative;
      background: rgba(255,255,255,.04);
      border: 1px solid rgba(255,255,255,.08);
      border-radius: var(--radius-card);
      padding: 2.5rem 2rem 2rem;
      text-align: center;
    }
    .step__num {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 52px;
      height: 52px;
      border-radius: 50%;
      background: var(--color-primary);
      font-family: var(--font-heading);
      font-size: 1.4rem;
      font-weight: 800;
      color: #fff;
      margin: 0 auto 1.25rem;
    }
    .step__title {
      font-family: var(--font-heading);
      font-size: 1.2rem;
      font-weight: 700;
      letter-spacing: .05em;
      text-transform: uppercase;
      color: #fff;
      margin-bottom: .6rem;
    }
    .step__body { color: rgba(255,255,255,.65); font-size: .92rem; line-height: 1.65; }

    /* ── Stats Bar ── */
    .stats {
      background: var(--color-primary);
      padding: 3rem 1.5rem;
    }
    .stats__inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1.5rem;
      text-align: center;
    }
    .stat__number {
      font-family: var(--font-heading);
      font-size: clamp(2.4rem, 5vw, 3.8rem);
      font-weight: 800;
      color: #fff;
      line-height: 1;
      letter-spacing: .02em;
    }
    .stat__label {
      font-size: .85rem;
      font-weight: 700;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: rgba(255,255,255,.75);
      margin-top: .4rem;
    }

    /* ── Features ── */
    .features__grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.25rem;
    }
    .feature-card {
      background: #fff;
      border-radius: var(--radius-card);
      padding: 1.5rem 1.5rem 1.5rem 1.75rem;
      box-shadow: 0 2px 10px rgba(0,0,0,.06);
      display: flex;
      align-items: flex-start;
      gap: 1rem;
    }
    .feature-card__check {
      flex-shrink: 0;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: var(--color-primary);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-top: 2px;
    }
    .feature-card__check::after {
      content: '';
      width: 6px;
      height: 10px;
      border-right: 2px solid #fff;
      border-bottom: 2px solid #fff;
      transform: rotate(45deg) translate(-1px, -1px);
      display: block;
    }
    .feature-card__text {}
    .feature-card__title {
      font-family: var(--font-heading);
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: .04em;
      text-transform: uppercase;
      color: var(--dark);
      margin-bottom: .25rem;
    }
    .feature-card__body { color: #666; font-size: .88rem; line-height: 1.55; }

    /* ── Testimonials ── */
    .testimonials__grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem;
    }
    .testimonial-card {
      background: rgba(255,255,255,.05);
      border: 1px solid rgba(255,255,255,.1);
      border-radius: var(--radius-card);
      padding: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .testimonial-card__stars {
      display: flex;
      gap: 2px;
      color: var(--color-primary);
      font-size: 1rem;
    }
    .testimonial-card__quote {
      font-size: .97rem;
      color: rgba(255,255,255,.85);
      line-height: 1.7;
      flex: 1;
    }
    .testimonial-card__author {
      display: flex;
      align-items: center;
      gap: .85rem;
    }
    .testimonial-card__avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
      background: rgba(255,255,255,.1);
    }
    .testimonial-card__name {
      font-family: var(--font-heading);
      font-weight: 700;
      font-size: .95rem;
      letter-spacing: .05em;
      text-transform: uppercase;
      color: #fff;
    }
    .testimonial-card__meta { font-size: .8rem; color: rgba(255,255,255,.5); margin-top: .1rem; }

    /* ── FAQ ── */
    .faq__list {
      max-width: 780px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: .6rem;
    }
    .faq-item {
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid #e5e5e5;
      background: #fff;
    }
    .faq-item__question {
      width: 100%;
      background: none;
      border: none;
      padding: 1.25rem 1.5rem;
      text-align: left;
      font-family: var(--font-body);
      font-size: .97rem;
      font-weight: 700;
      color: var(--dark);
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      transition: background .15s;
    }
    .faq-item__question:hover { background: #fafafa; }
    .faq-item__icon {
      flex-shrink: 0;
      width: 26px;
      height: 26px;
      border-radius: 50%;
      background: var(--mid);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background .2s, transform .2s;
      font-size: 1rem;
      color: var(--dark);
      line-height: 1;
    }
    .faq-item.is-open .faq-item__icon {
      background: var(--color-primary);
      color: #fff;
      transform: rotate(45deg);
    }
    .faq-item__icon::before { content: '+'; display: block; }
    .faq-item__answer {
      display: none;
      padding: 0 1.5rem 1.25rem;
      color: #555;
      font-size: .95rem;
      line-height: 1.75;
      border-top: 1px solid #eee;
    }
    .faq-item.is-open .faq-item__answer { display: block; }

    /* ── CTA Band ── */
    .cta-band {
      background: var(--dark);
      padding: 5.5rem 1.5rem;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cta-band::before {
      content: '';
      position: absolute;
      top: -50%;
      left: 50%;
      transform: translateX(-50%);
      width: 700px;
      height: 700px;
      border-radius: 50%;
      background: radial-gradient(circle, color-mix(in srgb, var(--color-primary) 18%, transparent) 0%, transparent 70%);
      pointer-events: none;
    }
    .cta-band__inner { position: relative; max-width: 700px; margin: 0 auto; }
    .cta-band__label {
      display: inline-block;
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--color-primary);
      margin-bottom: 1rem;
    }
    .cta-band__heading {
      font-family: var(--font-heading);
      font-size: clamp(2rem, 5vw, 3.4rem);
      font-weight: 800;
      text-transform: uppercase;
      color: #fff;
      letter-spacing: .04em;
      line-height: 1.08;
      margin-bottom: .9rem;
    }
    .cta-band__sub {
      color: rgba(255,255,255,.6);
      font-size: 1rem;
      margin-bottom: 2.25rem;
    }
    .cta-band__actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

    /* ── Footer ── */
    .footer { background: #0a0a0a; color: rgba(255,255,255,.75); padding: 5rem 1.5rem 0; }
    .footer__inner {
      max-width: 1200px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 2fr 1fr 1fr;
      gap: 3.5rem;
      padding-bottom: 4rem;
      border-bottom: 1px solid rgba(255,255,255,.07);
    }
    .footer__logo-text {
      font-family: var(--font-heading);
      font-size: 1.6rem;
      font-weight: 800;
      color: #fff;
      letter-spacing: .07em;
      text-transform: uppercase;
    }
    .footer__logo-img { height: 34px; width: auto; margin-bottom: .75rem; }
    .footer__tagline { font-size: .88rem; color: rgba(255,255,255,.45); margin-top: .6rem; margin-bottom: 1.5rem; max-width: 32ch; line-height: 1.6; }
    .footer__socials { display: flex; gap: .75rem; }
    .footer__social-link {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: rgba(255,255,255,.07);
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(255,255,255,.55);
      transition: background .2s, color .2s;
    }
    .footer__social-link:hover { background: var(--color-primary); color: #fff; }
    .footer h4 {
      font-family: var(--font-heading);
      font-size: .75rem;
      font-weight: 700;
      letter-spacing: .14em;
      text-transform: uppercase;
      color: rgba(255,255,255,.35);
      margin-bottom: 1.25rem;
    }
    .footer__links ul { display: flex; flex-direction: column; gap: .7rem; }
    .footer__links a { color: rgba(255,255,255,.65); font-size: .9rem; transition: color .2s; }
    .footer__links a:hover { color: #fff; }
    .footer__contact p { font-size: .9rem; color: rgba(255,255,255,.65); margin-bottom: .45rem; line-height: 1.5; }
    .footer__contact a:hover { color: #fff; }
    .footer__hours { margin-top: 1rem; display: flex; flex-direction: column; gap: .3rem; }
    .footer__hours-row { display: flex; justify-content: space-between; font-size: .82rem; color: rgba(255,255,255,.45); gap: 1rem; }
    .footer__bottom { max-width: 1200px; margin: 0 auto; padding: 1.5rem 0 2rem; }
    .footer__bottom-inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; }
    .footer__bottom p { font-size: .8rem; color: rgba(255,255,255,.3); }
    .footer__bottom-cta { font-size: .82rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: var(--color-primary); transition: opacity .2s; }
    .footer__bottom-cta:hover { opacity: .7; }
    @media (max-width: 768px) {
      .footer__inner { grid-template-columns: 1fr; gap: 2.5rem; }
    }
  </style>
</head>
<body>

{{> navbar}}

<!-- ── HERO ── -->
<section class="hero" data-section="hero">
  <div class="hero__content">
    <span class="hero__eyebrow">{{config.city}} · {{config.gym_type}}</span>
    <h1 class="hero__headline" data-content="hero.headline">{{page.hero_headline}}</h1>
    <p class="hero__subheading" data-content="hero.subheading">{{page.hero_subheading}}</p>
    <div class="hero__ctas">
      {{#if page.hero_cta_text}}
        <a href="{{page.hero_cta_url}}" class="btn btn--primary" data-content="hero.cta_primary">{{page.hero_cta_text}}</a>
      {{/if}}
      {{#if page.hero_secondary_cta_text}}
        <a href="{{page.hero_secondary_cta_url}}" class="btn btn--outline" data-content="hero.cta_secondary">{{page.hero_secondary_cta_text}}</a>
      {{/if}}
    </div>
  </div>
  {{#if page.hero_image_url}}
  <div class="hero__image">
    <img src="{{page.hero_image_url}}" alt="{{config.name}}" data-content="hero.image" />
  </div>
  {{/if}}
</section>

{{#each sections}}

  {{!-- HIGHLIGHTS --}}
  {{#eq section_type "highlights"}}
  <section class="section section--mid" data-section="highlights">
    <div class="section__inner">
      {{#if heading}}
      <div class="section__header">
        <span class="section__label">Why Us</span>
        <h2 class="section__heading" data-content="highlights.heading">{{heading}}</h2>
        {{#if subheading}}<p class="section__subheading" data-content="highlights.subheading">{{subheading}}</p>{{/if}}
      </div>
      {{/if}}
      <div class="highlights__grid" data-content="highlights.items">
        {{#each items}}
        <div class="highlight-card">
          <div class="highlight-card__icon">&#9679;</div>
          <h3 class="highlight-card__title" data-content="highlight.{{@index}}.title">{{title}}</h3>
          <p class="highlight-card__body" data-content="highlight.{{@index}}.body">{{short_body}}</p>
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/eq}}

  {{!-- PROGRAMS --}}
  {{#eq section_type "programs"}}
  <section class="section" data-section="programs">
    <div class="section__inner">
      {{#if heading}}
      <div class="section__header">
        <span class="section__label">What We Offer</span>
        <h2 class="section__heading" data-content="programs.heading">{{heading}}</h2>
        {{#if subheading}}<p class="section__subheading" data-content="programs.subheading">{{subheading}}</p>{{/if}}
      </div>
      {{/if}}
      <div class="programs__grid" data-content="programs.items">
        {{#each items}}
        <div class="program-card">
          {{#if image_url}}
          <div class="program-card__img-wrap">
            <img class="program-card__img" src="{{image_url}}" alt="{{title}}" data-content="program.{{@index}}.image" />
            <div class="program-card__overlay"></div>
          </div>
          {{/if}}
          <div class="program-card__body">
            <h3 class="program-card__title" data-content="program.{{@index}}.title">{{title}}</h3>
            <p class="program-card__desc" data-content="program.{{@index}}.body">{{short_body}}</p>
            {{#if cta_text}}
            <a href="{{cta_url}}" class="program-card__cta" data-content="program.{{@index}}.cta">
              {{cta_text}} <span aria-hidden="true">&rarr;</span>
            </a>
            {{/if}}
          </div>
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/eq}}

  {{!-- STEPS (3-step process) --}}
  {{#eq section_type "steps"}}
  <section class="section section--dark" data-section="steps">
    <div class="section__inner">
      {{#if heading}}
      <div class="section__header">
        <span class="section__label">How It Works</span>
        <h2 class="section__heading" data-content="steps.heading">{{heading}}</h2>
        {{#if subheading}}<p class="section__subheading" data-content="steps.subheading">{{subheading}}</p>{{/if}}
      </div>
      {{/if}}
      <div class="steps__grid" data-content="steps.items">
        {{#each items}}
        <div class="step">
          <div class="step__num">{{#if metadata.step_number}}{{metadata.step_number}}{{else}}{{stepNumber @index}}{{/if}}</div>
          <h3 class="step__title" data-content="step.{{@index}}.title">{{title}}</h3>
          <p class="step__body" data-content="step.{{@index}}.body">{{short_body}}</p>
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/eq}}

  {{!-- FEATURES --}}
  {{#eq section_type "features"}}
  <section class="section section--mid" data-section="features">
    <div class="section__inner">
      {{#if heading}}
      <div class="section__header">
        <span class="section__label">Included</span>
        <h2 class="section__heading" data-content="features.heading">{{heading}}</h2>
        {{#if subheading}}<p class="section__subheading" data-content="features.subheading">{{subheading}}</p>{{/if}}
      </div>
      {{/if}}
      <div class="features__grid" data-content="features.items">
        {{#each items}}
        <div class="feature-card">
          <div class="feature-card__check"></div>
          <div class="feature-card__text">
            <div class="feature-card__title" data-content="feature.{{@index}}.title">{{title}}</div>
            {{#if short_body}}<p class="feature-card__body" data-content="feature.{{@index}}.body">{{short_body}}</p>{{/if}}
          </div>
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/eq}}

  {{!-- TESTIMONIALS --}}
  {{#eq section_type "testimonials"}}
  <section class="section section--dark" data-section="testimonials">
    <div class="section__inner">
      {{#if heading}}
      <div class="section__header">
        <span class="section__label">Member Stories</span>
        <h2 class="section__heading" data-content="testimonials.heading">{{heading}}</h2>
        {{#if subheading}}<p class="section__subheading" data-content="testimonials.subheading">{{subheading}}</p>{{/if}}
      </div>
      {{/if}}
      <div class="testimonials__grid" data-content="testimonials.items">
        {{#each items}}
        <div class="testimonial-card">
          <div class="testimonial-card__stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <p class="testimonial-card__quote" data-content="testimonial.{{@index}}.quote">&ldquo;{{body}}&rdquo;</p>
          <div class="testimonial-card__author">
            {{#if image_url}}
              <img src="{{image_url}}" alt="{{title}}" class="testimonial-card__avatar" data-content="testimonial.{{@index}}.avatar" />
            {{else}}
              <div class="testimonial-card__avatar"></div>
            {{/if}}
            <div>
              <div class="testimonial-card__name" data-content="testimonial.{{@index}}.name">{{title}}</div>
              {{#if metadata.role}}<div class="testimonial-card__meta">{{metadata.role}}</div>{{/if}}
            </div>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/eq}}

  {{!-- FAQ --}}
  {{#eq section_type "faq"}}
  <section class="section" data-section="faq">
    <div class="section__inner">
      {{#if heading}}
      <div class="section__header">
        <span class="section__label">FAQ</span>
        <h2 class="section__heading" data-content="faq.heading">{{heading}}</h2>
        {{#if subheading}}<p class="section__subheading" data-content="faq.subheading">{{subheading}}</p>{{/if}}
      </div>
      {{/if}}
      <div class="faq__list" data-content="faq.items">
        {{#each items}}
        <div class="faq-item">
          <button class="faq-item__question" aria-expanded="false" data-content="faq.{{@index}}.question">
            {{title}}
            <span class="faq-item__icon" aria-hidden="true"></span>
          </button>
          <div class="faq-item__answer" data-content="faq.{{@index}}.answer">{{body}}</div>
        </div>
        {{/each}}
      </div>
    </div>
  </section>
  {{/eq}}

  {{!-- CTA BAND --}}
  {{#eq section_type "cta"}}
  <section class="cta-band" data-section="cta">
    <div class="cta-band__inner">
      <span class="cta-band__label">Ready to Start?</span>
      <h2 class="cta-band__heading" data-content="cta.heading">{{heading}}</h2>
      {{#if subheading}}<p class="cta-band__sub" data-content="cta.subheading">{{subheading}}</p>{{/if}}
      <div class="cta-band__actions">
        {{#if ../config.booking_url}}
          <a href="{{../config.booking_url}}" class="btn btn--primary" data-content="cta.button">Book a Free Intro</a>
        {{/if}}
        {{#if ../config.phone}}
          <a href="tel:{{../config.phone}}" class="btn btn--outline" data-content="cta.phone">Call {{../config.phone}}</a>
        {{/if}}
      </div>
    </div>
  </section>
  {{/eq}}

{{/each}}

{{> footer}}

<script>
  // FAQ accordion
  document.querySelectorAll('.faq-item__question').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const isOpen = item.classList.contains('is-open');
      document.querySelectorAll('.faq-item').forEach(i => {
        i.classList.remove('is-open');
        i.querySelector('.faq-item__question').setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

</body>
</html>
